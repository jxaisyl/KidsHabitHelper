/* 数据统计 */
.stats-row {
  gap: 16rpx;
}

.stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 10rpx;
}

.stat-num {
  font-size: 36rpx;
  font-weight: bold;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

/* 设置项 */
.setting-item {
  padding: 24rpx 0;
  font-size: 30rpx;
  color: var(--text-primary);
}

.setting-item + .setting-item {
  border-top: 1rpx solid var(--divider-color);
}

.setting-icon {
  margin-right: 16rpx;
  font-size: 32rpx;
}
