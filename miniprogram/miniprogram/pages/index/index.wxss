/* pages/index/index.wxss */

.header {
  padding: 20rpx 0 30rpx;
}

.header-top {
  margin-bottom: 10rpx;
}

.title-text {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.header-date {
  font-size: 24rpx;
}

/* 孩子卡片 */
.child-card {
  transition: all 0.2s ease;
}

.child-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.child-header {
  padding: 4rpx 0;
}

.child-info {
  flex: 1;
}

.child-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: var(--primary-light);
  margin-right: 20rpx;
}

.avatar-text {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.child-name-wrap {
  display: flex;
  flex-direction: column;
}

.child-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.child-age {
  font-size: 24rpx;
  margin-top: 4rpx;
}

.child-balance {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.balance-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.balance-value {
  font-size: 30rpx;
  font-weight: bold;
}

/* 添加按钮 */
.add-btn-wrap {
  position: fixed;
  bottom: 180rpx;
  left: 0;
  right: 0;
  padding: 0 60rpx;
  z-index: 10;
}

.add-btn {
  width: 100%;
  box-shadow: 0 6rpx 20rpx rgba(0, 150, 136, 0.3);
}

/* 加载 */
.loading-wrap {
  padding-top: 100rpx;
}
